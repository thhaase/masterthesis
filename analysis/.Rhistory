# === Baseline ===
m0 <- glm(populism_binary ~ mean_alter_degree,
family = binomial(link = "logit"),
data = d_ego)
summary(m0)
m0 <- lm(mean_alter_degree ~ populism_binary,
data = d_ego)
summary(m0)
m1 <- lm(mean_alter_degree ~ populism_binary +
ego_degree +
user_followers +
vader_sentiment_mean,
data = d_ego)
summary(m1)
# === Full ===
m1 <- glm(populism_binary ~ mean_alter_degree +
ego_degree +
user_followers +
vader_sentiment_mean,
family = binomial(link = "logit"),
data = d_ego)
summary(m1)
View(d_ego)
rm(list = ls())
